# Frontend
NEXT_PUBLIC_API_URL=https://your-container-url.cloud.yandex.net

# Backend
DATABASE_URL=postgresql+psycopg://book_user:change_me@localhost:5432/books
DB_URL=postgresql+psycopg://book_user:change_me@db-host:6432/books
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000

# Deployment
YC_REGISTRY_ID=crpxxxxxxxxxxxxxx
YC_CONTAINER_NAME=book-api
YC_FOLDER_ID=b1gxxxxxxxxxxxxxx
YC_CLOUD_ID=b1gxxxxxxxxxxxxxx
YC_SERVICE_ACCOUNT_ID=ajexxxxxxxxxxxxxx
YC_SA_KEY_JSON={"id":"...","service_account_id":"...","private_key":"..."}
YC_TOKEN=t1.xxxxxxxxxxxxxx
VERCEL_ORG_ID=team_xxxxxxxxxxxx
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxx
VERCEL_TOKEN=xxxxxxxxxxxxxx

# Terraform variables, set locally or as TF_VAR_* in CI when running terraform plan/apply
